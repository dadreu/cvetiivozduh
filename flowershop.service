[Unit]
Description=FlowerShop ASP.NET Core Application
After=network.target

[Service]
WorkingDirectory=/var/www/flowershop/backend
ExecStart=/usr/bin/dotnet /var/www/flowershop/backend/FlowerShop.Backend.dll
Restart=always
# Задержка перед перезапуском
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=flowershop
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=DOTNET_PRINT_TELEMETRY_MESSAGE=false

[Install]
WantedBy=multi-user.target
